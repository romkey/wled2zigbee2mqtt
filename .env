#MQTT_URL=mqtt://mqtt.cats:1883
MQTT_URL=mqtt://10.0.1.11:1883
MQTT_USERNAME=zigbee2mqtt
MQTT_PASSWORD=foobar
MQTT_BASE_TOPIC=zigbee2mqtt

DDP_HOST=0.0.0.0
DDP_PORT=4048

AUTO_DISCOVER=true
BULBS_FILE=/config/bulbs.json
DISCOVERY_OUTPUT=/config/bulbs.generated.json

FRAME_INTERVAL_MS=750
CHANGE_THRESHOLD=3
TRANSITION_SECONDS=0.5
TURN_OFF_AT_BLACK=true

PUBLISH_BATCH_SIZE=25
PUBLISH_BATCH_DELAY_MS=25
PUBLISH_RETAIN=false
